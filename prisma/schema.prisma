generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        String   @id @default(uuid())
  name      String
  color     String?
  createdAt DateTime @default(now())
  items     Item[]
}

model Item {
  id           String    @id @default(uuid())
  url          String
  title        String
  thumbnailUrl String?
  platform     String
  note         String?
  category     Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId   String?
  createdAt    DateTime  @default(now())

  @@index([categoryId])
  @@index([createdAt])
}
